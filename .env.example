# ============================================================================
# All env vars below are OPTIONAL.
#
# When NONE are set, the app boots in "legacy single-tenant mode":
#   - No auth gate (anyone can view the dashboards)
#   - No DB (clients are scanned from public/csvs/<slug>/ on disk)
#   - /admin/* and /api/clients/*, /api/agency, /api/billing return 503
#     (or render a "multi-tenant disabled" notice)
#
# Set AUTH_SECRET + DATABASE_URL to enable the full multi-tenant Tier 3
# experience. See TIER-3-DEPLOY-SAFE-CHANGES.md for the full guard matrix.
# ============================================================================

# ─── Authentication (NextAuth v5 / auth.js) ───────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
# If unset: middleware passes everything through; /admin/* unreachable
# (redirects to "/" via requireUser). The dashboard runs in no-auth mode.
AUTH_SECRET="change-me-openssl-rand-base64-32"

# Public URL of the deployed app. On Vercel this is auto-set as VERCEL_URL,
# but auth.js prefers an explicit NEXTAUTH_URL in some flows.
# If unset: NextAuth falls back to VERCEL_URL / request host.
NEXTAUTH_URL="http://localhost:3000"

# ─── Database ─────────────────────────────────────────────────────────
# libsql (Turso/SQLite) connection.
#   Dev example:   DATABASE_URL="file:./data/dev.db"
#   Turso example: DATABASE_URL="libsql://<your-db>.turso.io"
# If unset: lib/db exports a stub client that returns empty arrays for
# all queries. Admin/billing/upload routes return 503; audit/[client]
# falls back to public/csvs/<slug>/ on disk and still reconciles the
# take-charge-roofing baseline ($3,137.11 / 31 leads).
DATABASE_URL="file:./data/dev.db"

# Only needed for Turso (hosted libsql).
# DATABASE_AUTH_TOKEN=""

# ─── Seed admin (used by `npm run db:seed`) ───────────────────────────
# Change before deploying. The seed will (re)create this admin user.
# If unset and you run the seeder, it uses the defaults baked into scripts/seed.ts.
SEED_ADMIN_EMAIL="lesterortiz39@gmail.com"
SEED_ADMIN_PASSWORD="change-me-on-first-login"

# ─── Billing (Stripe) ─────────────────────────────────────────────────
# Tier 4 — Stripe Checkout for Pro / Agency plans.
# If any of these are unset, /api/billing/* routes return 503 with a clear
# error and the rest of the app keeps working.
#
# Get test keys: https://dashboard.stripe.com/test/apikeys
# Create products in test mode, then paste their price IDs below.
# See STRIPE-SETUP-GUIDE.md for the full walkthrough.

# Secret API key (sk_test_... in test mode, sk_live_... in prod).
STRIPE_SECRET_KEY="sk_test_..."

# Webhook signing secret (whsec_...) — from the webhook endpoint you create
# in the Stripe dashboard. Required for /api/billing/webhook to accept events.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs (price_xxx) for the two paid tiers. Create the products in
# Stripe dashboard → Products, with recurring monthly billing at $99 and $299.
STRIPE_PRO_PRICE_ID="price_..."     # Pro — $99 / month
STRIPE_AGENCY_PRICE_ID="price_..."  # Agency — $299 / month

# Public app URL — used to build Stripe success/cancel return URLs.
# On Vercel: https://marketing-auditor.vercel.app (or your custom domain).
NEXT_PUBLIC_APP_URL="https://marketing-auditor.vercel.app"
