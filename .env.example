# ─── Authentication (NextAuth v5 / auth.js) ───────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
AUTH_SECRET="change-me-openssl-rand-base64-32"

# Public URL of the deployed app. On Vercel this is auto-set as VERCEL_URL,
# but auth.js prefers an explicit NEXTAUTH_URL in some flows.
NEXTAUTH_URL="http://localhost:3000"

# ─── Database ─────────────────────────────────────────────────────────
# Dev: SQLite file. Prod: Postgres connection string (Neon, Supabase, etc).
#   Dev example:   DATABASE_URL="file:./dev.db"
#   Prod example:  DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# ─── Seed admin (used by `prisma db seed`) ────────────────────────────
# Change before deploying. The seed will (re)create this admin user.
SEED_ADMIN_EMAIL="lesterortiz39@gmail.com"
SEED_ADMIN_PASSWORD="change-me-on-first-login"

# ─── Tier 1: Puppeteer PDF export (informational) ─────────────────────
# When Tier 1 has merged, the PDF route uses these to find Chromium in
# serverless. No value needed locally — Tier 1 detects.
# CHROMIUM_REMOTE_EXEC_PATH="https://github.com/Sparticuz/chromium/releases/download/v131.0.1/chromium-v131.0.1-pack.tar"

# ─── Billing (TODO: Stripe) ───────────────────────────────────────────
# Placeholder for Tier 4 Stripe integration. Not used yet.
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
