{
  "name": "sna-marketing-auditor",
  "version": "2.0.0",
  "description": "SNA Forensic Marketing Auditor — Next.js live shell with dynamic audit engine.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "audit": "tsc -p tsconfig.engine.json && node ./dist/engine/index.js",
    "engine:test": "tsc -p tsconfig.engine.json && node ./dist/engine/index.js --csv-dir ./public/csvs/take-charge-roofing --client \"Take Charge Roofing\" --output ./reports/take-charge-roofing.html",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next dist",
    "dev:fresh": "rm -rf .next && next dev",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.7",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.0-beta.4",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5"
  }
}
